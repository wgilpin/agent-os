    { "type": "text", "id": "t_title", "x": 60, "y": 26, "width": 1040, "height": 34, "text": "Agent OS — Architecture after Phase 3 (Manifest Enforcement / v2)", "originalText": "Agent OS — Architecture after Phase 3 (Manifest Enforcement / v2)", "fontSize": 26, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100001, "version": 1, "versionNonce": 1, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "t_sub", "x": 60, "y": 64, "width": 1040, "height": 22, "text": "The deterministic gate is the only firewall — the untrusted agent only PROPOSES; the substrate CONFERS and acts.", "originalText": "The deterministic gate is the only firewall — the untrusted agent only PROPOSES; the substrate CONFERS and acts.", "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100002, "version": 1, "versionNonce": 1, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

