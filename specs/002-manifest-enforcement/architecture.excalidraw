    { "type": "rectangle", "id": "man_snip", "x": 470, "y": 394, "width": 268, "height": 116, "strokeColor": "#1e293b", "backgroundColor": "#1e293b", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300002, "version": 1, "versionNonce": 1, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "man_code", "x": 484, "y": 404, "width": 248, "height": 96, "text": "grants:\n  - connector: external_send\n    recipients: [owner-inbox]\n    methods: [send]\nspend: {cap, window, on_breach}", "originalText": "grants:\n  - connector: external_send\n    recipients: [owner-inbox]\n    methods: [send]\nspend: {cap, window, on_breach}", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#22c55e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 300003, "version": 1, "versionNonce": 1, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
